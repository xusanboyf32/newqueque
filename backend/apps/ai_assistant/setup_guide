============================

PYTHON CODE:
from apps.ai_assistant.services import ask_ai

# Oddiy savol
response = ask_ai(request.user, "Qandli diabet nima?")
print(response['response'])

# Davom ettirish
response2 = ask_ai(
    request.user,
    "Uni qanday oldini olish mumkin?",
    conversation_id=response['conversation_id']
)

# Klinika haqida
response3 = ask_ai(request.user, "Ko'z doktoringiz bormi?")

# Favqulodda
